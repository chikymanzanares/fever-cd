POSTGRES_DB=fever
POSTGRES_USER=fever
POSTGRES_PASSWORD=fever

POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000

DATABASE_URL=postgresql+psycopg2://fever:fever@db:5432/fever
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
PROVIDER_EVENTS_URL=https://provider.code-challenge.feverup.com/api/events
FEVER2_PROVIDER_EVENTS_URL=https://provider.code-challenge.feverup.com/api/events2
SEARCH_TIME_MODE=local

# URL pública del API en Render (opcional; copia a .env si quieres tenerla a mano)
PUBLIC_API_URL=
